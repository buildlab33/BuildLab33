# =============================================================================
# COP Platform Backend — Environment Variables
# Copy this file to backend/.env and fill in real values.
# Never commit the actual .env to git — it is gitignored.
# =============================================================================

# App
APP_ENV=development
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Supabase  (from your Supabase project → Settings → API)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# JWT  (generate a long random string — used to sign user tokens)
# Easy way: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=change-me-to-a-long-random-string

# Anthropic  (from console.anthropic.com → API Keys)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# NewsAPI  (from newsapi.org — free dev tier)
NEWSAPI_KEY=

# Resend  (for email outreach — leave blank until Phase 2)
RESEND_API_KEY=
RESEND_FROM_EMAIL=no-reply@cop-platform.dev

# Feature flags  (keep false in Phase 1)
SOCIAL_PUBLISH_ENABLED=false
EMAIL_SEND_ENABLED=false
